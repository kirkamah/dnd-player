{
  "appId": "org.noharm.dnd-player-trial",
  "productName": "DnD Player Trial",
  "directories": {
    "output": "release-trial",
    "buildResources": "build"
  },
  "files": ["dist/**", "electron/**", "build/icon.ico"],
  "win": {
    "target": ["portable"],
    "icon": "build/icon.ico"
  },
  "portable": {
    "artifactName": "DnD-Player-Trial.exe"
  },
  "afterPack": "scripts/afterPack.cjs",
  "mac": {
    "icon": "brand/logo.png",
    "category": "public.app-category.entertainment",
    "minimumSystemVersion": "11.0",
    "identity": null,
    "target": [
      { "target": "zip", "arch": ["x64", "arm64"] }
    ],
    "artifactName": "DnD-Player-mac-${arch}.${ext}"
  }
}
