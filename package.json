{
  "name": "dnd-player",
  "version": "0.1.0",
  "description": "Плеер формата .dndsession: рендер сцены слоями + синхронный мультитрек-звук",
  "author": "Kirkamah · no harm org",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "app": "npm run build && electron .",
    "dist": "npm run build && electron-builder --win",
    "dist:dir": "npm run build && electron-builder --win --dir",
    "dist:trial": "node scripts/build-trial.mjs"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "playwright": "^1.60.0",
    "png-to-ico": "^2.1.8",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "org.noharm.dnd-player",
    "productName": "DnD Player",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "electron/**",
      "build/icon.ico"
    ],
    "win": {
      "target": ["portable"],
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "DnD-Player-${version}.exe"
    }
  }
}
